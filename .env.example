# Copy this to .env and fill in real values.
# .env is gitignored — never commit actual secrets.

# ── Required ─────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your-discord-bot-token-here
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Point at wherever your HF model cache lives (default: ~/.cache/huggingface)
HF_HOME=D:\unsloth\hf_cache

# ── Optional: instant slash-command sync (copy your server's ID) ─────────────
DISCORD_GUILD_ID=

# ── Optional: restrict bot to one channel (copy channel ID) ──────────────────
DISCORD_ALLOWED_CHANNEL_ID=

# ── Optional: post online/offline announcements to this channel ──────────────
DISCORD_STATUS_CHANNEL_ID=

# ── Batch runner: webhook URL for programmatic dataset processing ─────────────
# Create via Discord Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=

# ── Optional: Claude API key for live log analysis (watch_logs.py) ───────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Ollama model selection ────────────────────────────────────────────────────
# Default: gemma4:e4b-it-q8_0 for both. See bot/README.md "Unsloth GGUFs"
# section for the lighter jemma-gemma option.
OLLAMA_MODEL_FAST=gemma4:e4b-it-q8_0
OLLAMA_MODEL_QUALITY=gemma4:e4b-it-q8_0
OLLAMA_URL=http://localhost:11434

# ── TRIBE inference tuning ────────────────────────────────────────────────────
# Must match model's training-time duration_trs (100). Do not change.
TRIBE_DURATION_TRS=100
