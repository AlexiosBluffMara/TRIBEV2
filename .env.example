# Copy this to .env and fill in real values.
# .env is gitignored — never commit actual secrets.

# ── Required ─────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your-discord-bot-token-here
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Point at wherever your HF model cache lives (default: ~/.cache/huggingface)
HF_HOME=D:\unsloth\hf_cache

# ── Optional: instant slash-command sync (copy your server's ID) ─────────────
DISCORD_GUILD_ID=

# ── Optional: restrict bot to one channel (copy channel ID) ──────────────────
DISCORD_ALLOWED_CHANNEL_ID=

# ── Optional: post online/offline announcements to this channel ──────────────
DISCORD_STATUS_CHANNEL_ID=

# ── Batch runner: webhook URL for programmatic dataset processing ─────────────
# Create via Discord Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=

# ── Optional: Claude API key for live log analysis (watch_logs.py) ───────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Ollama model selection ────────────────────────────────────────────────────
# Default: gemma4:e4b-it-q8_0 for both. See bot/README.md "Unsloth GGUFs"
# section for the lighter jemma-gemma option.
OLLAMA_MODEL_FAST=gemma4:e4b-it-q8_0
OLLAMA_MODEL_QUALITY=gemma4:e4b-it-q8_0
OLLAMA_URL=http://localhost:11434

# ── TRIBE inference tuning ────────────────────────────────────────────────────
# Must match model's training-time duration_trs (100). Do not change.
TRIBE_DURATION_TRS=100

# ── Kimi K2.5 (Moonshot AI) — required for Kimi Track / creative shader design ─
# Get key at: https://platform.moonshot.cn/  (or api.moonshot.ai outside China)
KIMI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-128k

# ── JemmaBrain Three.js web server ───────────────────────────────────────────
# Port the FastAPI backend listens on (Vite proxies /api + /ws + /mesh to it)
JEMMABRAIN_PORT=8765

# Public URL for the 3D viewer (ngrok / cloudflare / Cloud Run URL).
# Leave blank to use http://localhost:5173 (local only).
JEMMABRAIN_PUBLIC_URL=

# ── Google Cloud Platform ─────────────────────────────────────────────────────
# Run `python gcp/init.py` to fill these in automatically after `gcloud auth login`.

# GCP project ID (set by gcp/init.py)
GCP_PROJECT=

# Compute zone for inference VMs (L4 GPU, preemptible)
GCP_ZONE=us-central1-a

# GCS bucket for uploads, results, model weights
GCS_BUCKET=

# Base URL for brain mesh files served from GCS (speeds up Cloud Run deploys)
GCS_MESH_BASE=

# Docker image registry (Artifact Registry)
GCP_REGISTRY=

# Set to 1 to offload TRIBE v2 inference to a GCP GPU VM instead of local GPU.
# When enabled, submitting a Discord video spins up a preemptible L4 VM,
# runs the pipeline there, and syncs results back. Zero local GPU usage.
GCP_INFERENCE=0

# Billing account for auto-created projects (optional, format: XXXXXX-XXXXXX-XXXXXX)
GCP_BILLING_ACCOUNT=
